# Database Configuration (MongoDB Atlas)
MONGODB_URI=mongodb+srv://your_db_username:your_db_password@cluster0.xxxxx.mongodb.net/game_recommendation_db
DB_NAME=game_recommendation_db

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_replace_with_strong_random_string
JWT_EXPIRES_IN=24h

# External Game API Keys                                                                  
RAWG_API_KEY=your_rawg_api_key_here
IGDB_CLIENT_ID=your_igdb_client_id_here
IGDB_CLIENT_SECRET=your_igdb_client_secret_here
STEAM_API_KEY=your_steam_api_key_here

# Cache Configuration
CACHE_TTL_HOURS=24

# AI Discovery Configuration
ENABLE_AI_DISCOVERY=true
CRON_SCHEDULE=0 2 * * *

# Server Configuration
PORT=3000
NODE_ENV=development
SERVER_URL=http://localhost:3000
LOG_LEVEL=info

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
